% Coe College color theme for the Gemini beamerposter theme
% https://github.com/anishathalye/gemini
% Colors: Coe College Crimson/Maroon + Gold

% ====================
% Definitions
% ====================

\definecolor{coemaroon}{HTML}{561216}
\definecolor{coegold}{HTML}{A68145}
\definecolor{lightgray}{RGB}{240, 240, 240}

% ====================
% Theme
% ====================

% Basic colors
\setbeamercolor{palette primary}{fg=black,bg=white}
\setbeamercolor{palette secondary}{fg=black,bg=white}
\setbeamercolor{palette tertiary}{bg=coemaroon,fg=white}
\setbeamercolor{palette quaternary}{fg=black,bg=white}
\setbeamercolor{structure}{fg=coemaroon}

% Headline
\setbeamercolor{headline}{fg=coemaroon,bg=white}
\setbeamercolor{headline rule}{bg=coegold}
\setbeamercolor{headline title}{fg=coemaroon}
\setbeamercolor{headline author}{fg=black}
\setbeamercolor{headline institute}{fg=black}

% Block
\setbeamercolor{block title}{fg=white,bg=coemaroon}
\setbeamercolor{block separator}{bg=coegold}
\setbeamercolor{block body}{fg=black,bg=white}

% Alert block
\setbeamercolor{block title alerted}{fg=white,bg=coegold}
\setbeamercolor{block separator alerted}{bg=coemaroon}
\setbeamercolor{block body alerted}{fg=black,bg=white}

% Example block
\setbeamercolor{block title example}{fg=white,bg=black}
\setbeamercolor{block separator example}{bg=coegold}
\setbeamercolor{block body example}{fg=black,bg=white}

% Footer
\setbeamercolor{footline}{fg=white,bg=coemaroon}